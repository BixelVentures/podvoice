# ESPHome secrets for PodVoice firmware (podvoice.yaml).
# Copy this into the ESPHome add-on's Secrets editor (⋮ → Secrets) and fill in.

# --- Wi-Fi (2.4 GHz only — the Voice PE is 2.4 GHz) ---
wifi_ssid: "YourWiFiName"
wifi_password: "YourWiFiPassword"

# --- PodVoice API encryption key (Noise PSK) ---
# 32-byte base64. Use the SAME value in PodVoice → Settings → Voice PE PSK.
# Example below is freshly generated for you — fine to use as-is on a home LAN,
# or replace with your own (`openssl rand -base64 32`, or ESPHome's API key generator).
podvoice_api_key: "j9cvcoCxSjNVzRghGcJ8AHMcR9t/IGH5h4UbaJyfH3I="
