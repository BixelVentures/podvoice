# =============================================================================
# secrets.yaml.example  --  ESPHome secrets template for PodVoice Voice PE
# =============================================================================
#
# HOW TO USE:
#   1. Copy this file to `secrets.yaml` in the same directory:
#        cp secrets.yaml.example secrets.yaml
#   2. Fill in the real values below.
#   3. `secrets.yaml` MUST be gitignored -- it holds live credentials. Add a
#      `.gitignore` at the repo root containing at least:
#        esphome/secrets.yaml
#      (This `.example` file is the only secrets file that should ever be
#      committed.)
#
# voice-pe.yaml references these via `!secret <name>`.
# =============================================================================

# 32-byte base64 Noise PSK for the ESPHome native API encryption (PLAN 4.6).
# The SAME value must be set in the PodVoice add-on options as
# `voicepe_noise_psk` -- they must match exactly or PodVoice cannot connect.
# Generate one with: `openssl rand -base64 32`
podvoice_api_key: "REPLACE_WITH_32_BYTE_BASE64_NOISE_PSK"

# Wi-Fi the Voice PE joins on first boot.
wifi_ssid: "REPLACE_WITH_WIFI_SSID"
wifi_password: "REPLACE_WITH_WIFI_PASSWORD"
